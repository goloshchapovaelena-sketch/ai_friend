# ===================================
# AI Friend - Переменные окружения
# ===================================
# Скопируйте этот файл в .env и заполните значениями

# ⚠️ ВАЖНО: Для production (Render/Railway) используйте PostgreSQL!
# SQLite НЕ подходит для production - данные удаляются после перезапуска контейнера.

# ===================================
# Backend (FastAPI)
# ===================================

# GROQ API Key - получите на https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# База данных
# ⚠️ Для production (Render/Railway) используйте PostgreSQL!
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Для локальной разработки можно использовать SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./backend/ai_friend.db

# JWT Token настройки
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - разрешённые origin
# Для локальной разработки:
FRONTEND_URL=http://localhost:8080
# Для production (Vercel):
# FRONTEND_URL=https://ai-friend.vercel.app

# Приложение
APP_NAME=AI Friend
DEBUG=true

# ===================================
# Frontend (Vite/React)
# ===================================
# Переменные для frontend/.env

# URL API (для production сборки)
# VITE_API_URL=http://localhost:8000

# ===================================
# Порты
# ===================================
BACKEND_PORT=8000
FRONTEND_PORT=8080
