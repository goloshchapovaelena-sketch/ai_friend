# ===================================
# AI Friend - Backend Production .env
# ===================================
# Для Railway/Render/Production деплоя

# GROQ API Key
GROQ_API_KEY=your_groq_api_key_here

# База данных
# ⚠️ Для production (Render/Railway) используйте PostgreSQL!
# SQLite НЕ подходит для production - данные удаляются после перезапуска контейнера.
#
# Render: создайте базу данных в дашборде и скопируйте DATABASE_URL
# Railway: PostgreSQL создаётся автоматически, DATABASE_URL добавляется автоматически
#
# Пример для Render:
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Token настройки
JWT_SECRET_KEY=change_this_to_secure_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Production URL вашего frontend
FRONTEND_URL=https://ai-friend.vercel.app

# Приложение
APP_NAME=AI Friend
DEBUG=false
